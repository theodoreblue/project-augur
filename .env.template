# Project AUGUR — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. NEVER share these values.

# Kalshi API Key ID (the UUID shown on the API key page)
KALSHI_KEY_ID=your-key-id-uuid-here

# Path to your RSA private key file (generated when you created the API key)
KALSHI_PRIVATE_KEY_PATH=/home/jnyka/augur/kalshiprivatekey.pem

# Kalshi API base URL — do not change unless Kalshi migrates again
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# Set to "true" to use Kalshi demo API (no real money — for testing)
KALSHI_USE_DEMO=false

# Starting bankroll in USD
STARTING_BANKROLL=200.0
