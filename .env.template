# Project AUGUR — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. NEVER share these values.

# Kalshi API Key ID (the UUID shown on the API key page)
KALSHI_KEY_ID=your-key-id-uuid-here

# Option A: paste the full private key content here (replace newlines with \n)
KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR\nKEY\nHERE\n-----END RSA PRIVATE KEY-----

# Option B: path to saved private key file (easier — recommended)
# KALSHI_PRIVATE_KEY_PATH=/home/jnyka/augur/kalshi_private_key.pem

# Set to "true" to use Kalshi demo API (no real money — for testing)
KALSHI_USE_DEMO=false

# Starting bankroll in USD
STARTING_BANKROLL=50.0
