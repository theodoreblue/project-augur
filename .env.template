# Project AUGUR — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Kalshi API key (get from kalshi.com/api after KYC verification)
KALSHI_API_KEY=your_kalshi_api_key_here

# Set to "true" to use Kalshi demo API (no real money — for testing)
KALSHI_USE_DEMO=true

# Starting bankroll in USD (used for Kelly sizing)
STARTING_BANKROLL=50.0
